# ─── Stellar / Soroban ──────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=

# Signing key used by the backend to submit transactions
SOROBAN_SECRET_KEY=

# Reward asset issuer public key
ISSUER_PUBLIC_KEY=

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://questforge:questforge@localhost:5432/questforge

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production

# ─── App ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
